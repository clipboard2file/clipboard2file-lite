{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Clipboard2File Lite",
  "version": "1.0",
  "description": "Instantly upload pictures from your clipboard!",
  "icons": {
    "256": "./icons/clipboard2file.png"
  },
  "options_ui": {
    "page": "./settings/options.html"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "clipboardRead",
    "clipboardWrite",
    "storage",
    "offscreen"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "./background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "match_origin_as_fallback": true,
      "js": ["./content/all_frames.js"]
    },
    {
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "match_origin_as_fallback": true,
      "world": "MAIN",
      "js": ["./content/main_world_all_frames.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "settings/settings.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
